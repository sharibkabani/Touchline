# Data source: "espn" (live FIFA World Cup data) or "mock" (bundled JSON).
TOUCHLINE_PROVIDER=espn
TOUCHLINE_COMPETITION=world-cup
TOUCHLINE_MOCK_DIR=mock
# Override the ESPN scoreboard base URL (optional; leave blank for the default).
TOUCHLINE_ESPN_BASE_URL=
TOUCHLINE_REFRESH_INTERVAL=30s
TOUCHLINE_CACHE_TTL=25s
TOUCHLINE_LOG_LEVEL=info

# Serve the TUI over SSH (via charmbracelet/wish) instead of running locally.
TOUCHLINE_SSH=false
TOUCHLINE_SSH_ADDR=localhost:23234
# Host key is auto-generated on first run if it doesn't exist.
TOUCHLINE_SSH_HOST_KEY_PATH=.ssh/touchline_ed25519
